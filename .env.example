# Required secrets. install.sh fills these automatically on a VM.
ADMIN_PASSWORD=
SESSION_SECRET=

# Runtime
DATABASE_PATH=/app/data/app.db
# Set this to true only when the VM only accepts traffic from a trusted proxy
# such as Cloudflare or a reverse proxy that controls forwarding headers.
TRUST_PROXY_HEADERS=true

# Wedding content
COUPLE_NAMES=Lilly & Christopher
WEDDING_MONOGRAM=L&C
WEDDING_DATE=Saturday, September 26, 2026
WEDDING_DATE_ISO=2026-09-26
WEDDING_SHORT_DATE=9.26.2026
WEDDING_VENUE=The Hall
WEDDING_LOCATION=St Leon, IN
