# Local/test login only. Change before exposing the site publicly.
ADMIN_PASSWORD=admin
# Required secret used to sign admin session cookies.
SESSION_SECRET=
# Keep false for localhost or an isolated HTTP test VM. Set true for public HTTPS.
SESSION_COOKIE_SECURE=false

# Runtime
DATABASE_PATH=./data/app.db
# Set this to true only when the VM only accepts traffic from a trusted proxy
# such as Cloudflare or a reverse proxy that controls forwarding headers.
TRUST_PROXY_HEADERS=true

# Wedding content
COUPLE_NAMES=Mark & Guerdithe
FIRST_FULL_NAME=Mark Jerome Wolfe
SECOND_FULL_NAME=Guerdithe Mielda Nelson
HOST_NAMES=Amy and Jeremy Wolfe
WEDDING_MONOGRAM=M&G
WEDDING_DATE=Saturday, July 18, 2026
WEDDING_DATE_ISO=2026-07-18
WEDDING_SHORT_DATE=07.18.2026
CEREMONY_TIME=2:30 PM
CEREMONY_VENUE=St. Joseph's Catholic Church
# Leave blank until the real address is confirmed.
CEREMONY_ADDRESS=7536 Church Ln, West Harrison, IN 47060
RSVP_DEADLINE=June 26, 2026
RSVP_DEADLINE_ISO=2026-06-26
